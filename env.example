# ── Backend .env.example ─────────────────────────────────────────────────────
# Copy to .env and fill in real values. NEVER commit .env to the repo.

# PostgreSQL (Render external)
DATABASE_URL=postgresql://user:password@host/dbname

# AES-256 key for pgcrypto (exactly 32 chars)
AES_KEY=change_this_to_a_32_char_secret!!

# JWT
JWT_SECRET=change_this_jwt_secret_key_here
JWT_EXPIRE_HOURS=8

# CORS — comma-separated origins
ALLOWED_ORIGINS=["http://localhost:3000","https://your-frontend.vercel.app"]

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=clinical-images

# Microservices
ML_SERVICE_URL=http://ml-service:8001
DL_SERVICE_URL=http://dl-service:8002
ORCHESTRATOR_URL=http://orchestrator:8003
